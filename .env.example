# Copy to .env and fill in values.

POSTGRES_DB=trades
POSTGRES_USER=trades_user
POSTGRES_PASSWORD=changeme

FINNHUB_TOKEN=

# MinIO (local S3-compatible lake) — match MINIO_ROOT_* with AWS_* for dev
LAKE_ENABLED=true
S3A_ENDPOINT=http://minio:9000
S3A_BUCKET=financial-pipeline-datalake
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# AWS S3 later: set real keys, set LAKE_ENABLED=true, leave S3A_ENDPOINT empty (or regional HTTPS endpoint).
